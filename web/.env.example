# Privy — get your appId from https://dashboard.privy.io/
NEXT_PUBLIC_PRIVY_APP_ID=

# Manah contract address on Monad Testnet (deploy first, then fill)
NEXT_PUBLIC_MANAH_ADDRESS=

# Envio HyperIndex GraphQL endpoint
NEXT_PUBLIC_ENVIO_URL=

# Pyth Entropy on Monad Testnet (used by contract, exposed for UI display)
NEXT_PUBLIC_PYTH_ENTROPY_ADDRESS=

# Optional: override RPC for read-only calls (defaults to public Monad testnet RPC)
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
